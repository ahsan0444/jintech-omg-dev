{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'p=\"${CLAUDE_PLUGIN_ROOT}/hook-scripts/enforce-mcp-search.py\"; [ -f \"$p\" ] && python3 \"$p\" || exit 0'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'p=\"${CLAUDE_PLUGIN_ROOT}/hook-scripts/post-edit-update.py\"; [ -f \"$p\" ] && python3 \"$p\" || exit 0'",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'p=\"${CLAUDE_PLUGIN_ROOT}/hook-scripts/session-start-status.py\"; [ -f \"$p\" ] && python3 \"$p\" || exit 0'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
