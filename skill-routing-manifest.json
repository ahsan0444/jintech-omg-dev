    {
      "id": "pr-create",
      "patterns": [
        "\\b(create|raise|open|draft)\\s+(a\\s+)?pr\\b"
      ],
      "confidence": "high",
      "action": {
        "type": "skill",
        "skill": "jintech-omg-dev:pr"
      }
    },
    {
      "id": "pr-update",
      "patterns": [
        "\\bupdate\\b.*\\bpr\\b(?!.*description says)"
      ],
      "confidence": "high",
      "action": {
        "type": "skill",
        "skill": "jintech-omg-dev:pr"
      }
    },
    {
      "id": "pr-rebase",
      "patterns": [
        "\\brebase\\b.*\\b(pr|branch|onto)\\b"
